<Window x:Class="MegeonParserDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MegeonParserDesktop"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8 4"/>
        </Style>
    </Window.Resources>
    <DockPanel>
        <DockPanel DockPanel.Dock="Bottom">
            <ProgressBar x:Name="pbIndicator" Height="24" Maximum="1" Minimum="0" Value="0" />
        </DockPanel>
        <StackPanel>
            <DockPanel>
                <Button x:Name="btnParse" Content="Начать парсинг" Click="btnParse_Click" DockPanel.Dock="Left"/>
                <Button x:Name="btnDownloadResources" Content="Скачать ресурсы" Click="btnDownloadResources_Click" DockPanel.Dock="Left" />
                <TextBlock VerticalAlignment="Center" Margin="8 2 4 2">Папка для загрузки ресурсов</TextBlock>
                <TextBox x:Name="txtDownloadFolderPath" Margin="4"/>
            </DockPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="StartID: " Margin="4" />
                <TextBox x:Name="txtStartId" Text="-1" MinWidth="80" Margin="4" TextChanged="txtStartId_TextChanged"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnExportGeneral" Content="Товары" Click="btnExportGeneral_Click" />
                <Button x:Name="btnAdditionalImages" Content="Доп. изображения" Click="btnAdditionalImages_Click" />
                <Button x:Name="btnGetDescriptionUpdate" Content="DESK Update" Click="btnGetDescriptionUpdate_Click" />
                <Button x:Name="btnPdf" Content="PDF SQL" Click="btnPdf_Click" />
                <Button x:Name="btnDimensions" Content="Dimensions SQL" Click="btnDimensions_Click" />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
