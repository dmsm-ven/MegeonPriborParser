<Window x:Class="Megeon.StartIdInputForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Megeon"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        SizeToContent="WidthAndHeight"
        Title="Введите стартовый product_id" Height="87" Width="250">
    <StackPanel Margin="4">
        <TextBox x:Name="txtProductId" Text="0" Width="80"/>
        <Button IsDefault="True" Content="Выбрать" Margin="0 4 0 0" Padding="10" Click="Button_Click" />
    </StackPanel>
</Window>
